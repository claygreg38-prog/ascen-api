<script>
(function(){
'use strict';
function $(id){return document.getElementById(id)}
function clamp(v,lo,hi){return Math.max(lo,Math.min(hi,v))}
function lerp(a,b,t){return a+(b-a)*t}
function pick(a){return a[Math.floor(Math.random()*a.length)]}

/* COLOR RAMPS */
function lunoColor(t){const s=[[14,32,48],[26,56,72],[58,104,136],[74,152,184],[106,208,232],[160,240,255]];const i=clamp(t*5,0,4.999);const lo=Math.floor(i),hi=Math.ceil(i),f=i-lo;return[lerp(s[lo][0],s[hi][0],f),lerp(s[lo][1],s[hi][1],f),lerp(s[lo][2],s[hi][2],f)]}
function lunaColor(t){const s=[[58,16,32],[106,32,64],[176,48,112],[208,96,160],[224,128,192],[255,176,208]];const i=clamp(t*5,0,4.999);const lo=Math.floor(i),hi=Math.ceil(i),f=i-lo;return[lerp(s[lo][0],s[hi][0],f),lerp(s[lo][1],s[hi][1],f),lerp(s[lo][2],s[hi][2],f)]}
function rgb(c){return`rgb(${Math.round(c[0])},${Math.round(c[1])},${Math.round(c[2])})`}
function rgba(c,a){return`rgba(${Math.round(c[0])},${Math.round(c[1])},${Math.round(c[2])},${a})`}

let currentChar='luno', sessNum=1, cohPct=25;
let branches=[], orbits=[], emanations=[], breathInterval=null;
let currentCoreCol=[14,32,48]; // tracked globally for pulse rings
let inBreathingPhase=false;

/* ================================================================
   SOURCE-OF-LIGHT SYSTEM
================================================================ */

// Session milestone → revelation phrase shown during breathing
// Arc: from receiving light → becoming light → being light
const SOURCE_PHRASES = [
  [100,  "Something in you is waking."],
  [300,  "Your breath is making this light."],
  [800,  "The ocean is listening to you now."],
  [2000, "The darkness doesn't touch you anymore."],
  [4000, "Luno follows your lead."],
  [6500, "You illuminate this space."],
  [8500, "You were always the lamp."],
  [9500, "There is no guide here. Only you."]
];

function getSourcePhrase(){
  let phrase = '';
  for(const [thresh, txt] of SOURCE_PHRASES){
    if(sessNum >= thresh) phrase = txt;
  }
  return phrase;
}

function updateSourceText(){
  const st = $('sourceText');
  if(!inBreathingPhase || sessNum < 100){
    st.classList.remove('visible');
    return;
  }
  const phrase = getSourcePhrase();
  if(phrase){
    st.textContent = phrase;
    st.classList.add('visible');
  } else {
    st.classList.remove('visible');
  }
}

/* Build conic gradient for light rays from source point */
function buildRayGradient(col, strength){
  const r=Math.round(col[0]),g=Math.round(col[1]),b=Math.round(col[2]);
  // 20 rays, irregularly spaced for organic feel
  const offsets = [0,14,22,40,56,67,81,99,112,128,143,157,170,184,199,214,228,245,258,275,290,306,319,335,350];
  let cg = 'conic-gradient(from 0deg at 50% 91%,';
  for(let i=0;i<offsets.length;i++){
    const s = offsets[i];
    const next = offsets[(i+1)%offsets.length] || 360;
    const span = next - s;
    const rayWidth = span * (0.25 + (i%3)*0.08);
    const midS = s + (span-rayWidth)/2;
    const midE = midS + rayWidth;
    const rayOp = (0.035 + (i%4)*0.015) * strength;
    cg += `transparent ${s.toFixed(0)}deg,`;
    cg += `rgba(${r},${g},${b},${rayOp}) ${midS.toFixed(1)}deg,`;
    cg += `rgba(${r},${g},${b},${rayOp}) ${midE.toFixed(1)}deg,`;
    cg += `transparent ${Math.min(next,360).toFixed(0)}deg,`;
  }
  cg += `transparent 360deg)`;
  return cg;
}

/* Main light source rendering — called inside render() */
function renderLightSource(N, I, coreCol){
  // Lifetime strength: 0 at session 1, max ~1.0 at session 10000
  const sessStr = sessNum < 80 ? 0 : clamp((sessNum - 80) / 4920, 0, 1);
  // Coherence amplifies: base floor from sessions, peaks with coherence
  const lightStr = sessStr * (0.28 + I * 0.72);

  const ls = $('lightSourceLayer');
  const lr = $('lightRaysLayer');

  if(lightStr < 0.004){
    ls.style.opacity = '0';
    lr.style.opacity = '0';
  } else {
    // Source radiance — layered radial:
    // tight bright core at Luno position, broad ambient wash beyond
    const c1 = rgba(coreCol, Math.min(0.75, lightStr * 0.65)); // innermost, bright
    const c2 = rgba(coreCol, Math.min(0.35, lightStr * 0.30)); // mid diffusion
    const c3 = rgba(coreCol, Math.min(0.12, lightStr * 0.10)); // outer ambience

    // At very high sessions, the wash reaches the TOP of the screen
    // The environment is lit BY the user, not ambient
    const radH = 55 + lightStr * 40; // 55%→95% ellipse height
    const radW = 60 + lightStr * 30; // 60%→90% ellipse width

    ls.style.opacity = '1';
    ls.style.background =
      `radial-gradient(ellipse ${radW}% ${radH}% at 50% 93%,` +
      `${c1} 0%, ${c1} 4%, ${c2} 20%, ${c3} 42%, transparent 68%)`;

    // Rays
    lr.style.opacity = clamp(lightStr * 0.8, 0, 0.75).toFixed(2);
    lr.style.background = buildRayGradient(coreCol, lightStr);
  }

  // USER as co-source of light (porthole area)
  // Begins session 400, grows until session ~8000
  // At peak: user light is STRONGER than Luno — the arc completes
  const userBaseStr = sessNum < 400 ? 0 : clamp((sessNum - 400) / 5600, 0, 1);
  const userStr = userBaseStr * (0.35 + I * 0.65);
  const ul = $('userLight');

  if(userStr < 0.008){
    ul.style.opacity = '0';
  } else {
    // Size: starts small, expands to fill the porthole area and beyond
    const ulSz = 140 + userStr * 180;
    ul.style.width = ulSz + 'px';
    ul.style.height = ulSz + 'px';
    ul.style.opacity = '1';
    // Glow centered at porthole (top-right)
    ul.style.background =
      `radial-gradient(circle at 55% 45%,` +
      `${rgba(coreCol, userStr * 0.75)},` +
      `${rgba(coreCol, userStr * 0.35)} 38%,` +
      `${rgba(coreCol, userStr * 0.12)} 60%,` +
      `transparent 80%)`;
  }
}

/* Breath pulse ring — visual expansion of light on each breath cycle */
function triggerBreathPulse(phase){
  const sessStr = sessNum < 80 ? 0 : clamp((sessNum - 80) / 4920, 0, 1);
  if(sessStr < 0.04) return; // too early to show effect

  const I = effI(sessFloor(sessNum), cohPct) / 100;
  const N = Math.min(1, Math.log(Math.max(1, sessNum)) / Math.log(10000));
  const lunoSize = 120 + N * 100;

  const el = document.createElement('div');
  const startSz = lunoSize * 0.6;
  const endSz = 500 + sessStr * 400; // grows with lifetime
  const duration = phase === 'in' ? 3.2 : 4.5;
  const startOp = 0.45 + sessStr * 0.3;

  el.style.cssText = `
    position: absolute;
    left: 50%;
    bottom: calc(8% + ${lunoSize * 0.5 - startSz * 0.5}px);
    width: ${startSz}px;
    height: ${startSz}px;
    margin-left: ${-startSz * 0.5}px;
    border-radius: 50%;
    border: ${1.5 + sessStr * 1.5}px solid ${rgba(currentCoreCol, startOp)};
    box-shadow: 0 0 ${8 + sessStr * 14}px ${rgba(currentCoreCol, startOp * 0.5)},
                inset 0 0 ${4 + sessStr * 8}px ${rgba(currentCoreCol, startOp * 0.2)};
    z-index: 6;
    pointer-events: none;
    transition: width ${duration}s ease-out,
                height ${duration}s ease-out,
                margin-left ${duration}s ease-out,
                bottom ${duration}s ease-out,
                opacity ${duration * 0.85}s ease-out,
                border-color ${duration}s ease-out,
                box-shadow ${duration}s ease-out;
  `;

  $('immersiveView').appendChild(el);

  // Force reflow then animate outward
  void el.offsetWidth;
  const dSz = endSz - startSz;
  el.style.width = endSz + 'px';
  el.style.height = endSz + 'px';
  el.style.marginLeft = `${-endSz * 0.5}px`;
  el.style.bottom = `calc(8% + ${lunoSize * 0.5 - endSz * 0.5}px)`;
  el.style.opacity = '0';

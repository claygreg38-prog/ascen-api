  $('dialogue').style.display='block';
  $('tapP').style.display='none';
  document.querySelectorAll('.pb').forEach(b=>b.className='pb');
  if(event&&event.target&&event.target.classList) event.target.classList.add('active');

  inBreathingPhase = false;
  updateSourceText();

  const P={
    arrival:{l:'ARRIVAL',t:"Luno's checking in with you.<br>You don't have to do anything yet.<br>Just land.",tap:"Tap when you're ready"},
    opening:{l:'OPENING',t:"You made it here.<br><br>The people who came before you — <span class='hl'>they survived things that would break most people.</span><br><br>They made it through. And because they made it through — you are here.",tap:"Tap to continue"},
    resistance:{l:'RESISTANCE',t:"Your body might not trust this yet.<br><br>The part of you that stays ready — <span class='hl'>that part kept you here.</span><br><br>Don't ask it to stand down. Just breathe alongside it.",tap:"Tap to begin"},
    breathing:{l:'BREATHE',t:getBreathingDialogue(),pacer:true},
    shift:{l:'SHIFT',t:"",pacer:true,coh:78},
    checkin:{l:'REFLECT',ov:'checkinOv'},
    mirror:{l:'MIRROR',ov:'mirrorOv',onShow:function(){
      const el1=$('mirrorBreaths'); if(el1) el1.textContent=breathCount||0;
      const el2=$('mirrorCoh'); if(el2) el2.textContent=(cohPct/100).toFixed(2);
      const dur=sessionStartTime?Math.round((Date.now()-sessionStartTime)/60000):0;
      const el3=$('mirrorDur'); if(el3) el3.textContent=(dur||1)+'m';
    }},
    vault:{l:'VAULT',ov:'vaultOv'}
  };

  const x=P[p];
  if(!x) return;
  $('phaseLabel').textContent=x.l;

  if(x.ov){$(x.ov).className='ov active';$('dialogue').style.display='none';if(x.onShow)x.onShow();return}

  $('dText').innerHTML=x.t;

  if(x.pacer){
    $('breathPacer').style.display='flex';
    if(!x.t) $('dialogue').style.display='none';
    startBreath();
    startOrbitDot();
    // Activate source-of-light mode
    inBreathingPhase = true;
    updateSourceText();
  }

  if(x.tap){$('tapP').style.display='block';$('tapP').textContent=x.tap}
  if(x.coh){$('cohSlider').value=x.coh;cohPct=x.coh;render()}
};


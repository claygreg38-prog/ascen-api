let breathCount = 0;
let totalBreaths = 0;
let orbitRaf = null;

function startOrbitDot(){
  if(orbitRaf) cancelAnimationFrame(orbitRaf);
  const dot = $('orbitDot');
  const pacer = $('breathPacer');
  if(!dot || !pacer) return;

  // Orbit radius = half the pacer width (100px) — dot rides the ring edge
  const R = 96; // px from center
  const CENTER = 100; // pacer is 200x200, center at 100,100
  const DOT_R = 6;  // half dot size

  // Timing: IN=3s, OUT=3s, full cycle=6s
  // Inhale: top → right → bottom (0 → π, clockwise from top)
  // Exhale: bottom → left → top (π → 2π)
  // Read ratio from active session: e.g. "4-2-6" = 4s in, 2s hold, 6s out
  const _ratio = (activeApiSession && activeApiSession.ratio)
    ? activeApiSession.ratio.split('-').map(Number)
    : [4, 0, 6];
  const IN_MS   = (_ratio[0] || 4) * 1000;
  const HOLD_MS = (_ratio[1] || 0) * 1000;
  const OUT_MS  = (_ratio[2] || 6) * 1000;
  const CYCLE_MS = IN_MS + HOLD_MS + OUT_MS;

  let startTs = null;

  // Inhale color: teal. Exhale color: indigo.
  const inCol  = 'rgba(78,205,196,0.95)';
  const inGlow = '0 0 12px rgba(78,205,196,0.9), 0 0 24px rgba(78,205,196,0.4)';
  const outCol  = 'rgba(123,142,248,0.95)';
  const outGlow = '0 0 12px rgba(123,142,248,0.9), 0 0 24px rgba(123,142,248,0.4)';

  function frame(ts){
    if(!startTs) startTs = ts;
    const elapsed = (ts - startTs) % CYCLE_MS;
    const isInhale = elapsed < IN_MS;
    const isHold   = HOLD_MS > 0 && elapsed >= IN_MS && elapsed < IN_MS + HOLD_MS;
    const isExhale = elapsed >= IN_MS + HOLD_MS;

    // Angle: start at top (-π/2), clockwise
    // Inhale: top → bottom via right (0 → π)
    // Hold: stays at bottom
    // Exhale: bottom → top via left (π → 2π)
    let angle;
    if(isInhale){
      const t = elapsed / IN_MS;
      angle = -Math.PI/2 + t * Math.PI;
    } else if(isHold){
      angle = Math.PI/2; // stays at bottom during hold
    } else {
      const t = (elapsed - IN_MS - HOLD_MS) / OUT_MS;
      angle = Math.PI/2 + t * Math.PI;
    }

    const x = CENTER + R * Math.cos(angle) - DOT_R;
    const y = CENTER + R * Math.sin(angle) - DOT_R;

    dot.style.left = x + 'px';
    dot.style.top  = y + 'px';
    dot.style.background = isInhale ? inCol : outCol;
    dot.style.boxShadow  = isInhale ? inGlow : outGlow;

    orbitRaf = requestAnimationFrame(frame);
  }

  orbitRaf = requestAnimationFrame(frame);
}

function stopOrbitDot(){
  if(orbitRaf){ cancelAnimationFrame(orbitRaf); orbitRaf=null; }
}

const MAX_DOTS = 12;

function buildDots(total){
  const dotsEl = $('breathDots');
  if(!dotsEl) return;
  dotsEl.innerHTML = '';
  const show = Math.min(total, MAX_DOTS);
  for(let i = 0; i < show; i++){
    const d = document.createElement('div');
    d.className = 'bdot';
    d.id = 'bdot_' + i;
    dotsEl.appendChild(d);
  }
}

function updateDots(current, total){
  const show = Math.min(total, MAX_DOTS);
  const ratio = total > MAX_DOTS ? MAX_DOTS / total : 1;
  const activeDot = Math.min(Math.floor((current - 1) * ratio), show - 1);
  for(let i = 0; i < show; i++){
    const d = $('bdot_' + i);
    if(!d) continue;
    if(i < activeDot)      d.className = 'bdot done';
    else if(i===activeDot) d.className = 'bdot active';
    else                   d.className = 'bdot';
  }
}

function pulseBreathNum(){
  const el = $('breathNum');
  if(!el) return;
  el.style.animation = 'none';
  void el.offsetWidth;
  el.style.animation = 'breathPulseNum 0.8s ease-out forwards';
}

function startBreath(){
  clearTimeout(breathInterval); breathInterval=null;
  breathCount = 0;

  // Cycle = in + hold + out from session ratio
  const sessData = activeApiSession;
  const durSec = sessData ? (sessData.duration_seconds || 720) : 720;
  const bRatio = (sessData && sessData.ratio)
    ? sessData.ratio.split('-').map(Number)
    : [4, 0, 6];
  const bIn   = (bRatio[0] || 4);
  const bHold = (bRatio[1] || 0);
  const bOut  = (bRatio[2] || 6);
  const cycleSec = bIn + bHold + bOut;
  totalBreaths = Math.round(durSec / cycleSec);

  // Show counter
  const counterEl = $('breathCounter');
  const numEl     = $('breathNum');
  const totalEl   = $('breathTotal');
  if(counterEl) counterEl.style.display = 'flex';
  if(numEl)     numEl.textContent = '1';
  if(totalEl)   totalEl.textContent = totalBreaths;
  // Show ratio in bl-count label
  const blc=$('blCount'); if(blc){ blc.textContent=bIn+'-'+(bHold>0?bHold+'-':'')+bOut; blc.style.display='block'; }
  buildDots(totalBreaths);
  updateDots(1, totalBreaths);

  // Phase sequence: in → [hold] → out → repeat
  const phases = ['in'];
  if(bHold > 0) phases.push('hold');
  phases.push('out');
  let phaseIdx = 0;

  function phaseDuration(p){
    if(p === 'in')   return bIn   * 1000;
    if(p === 'hold') return bHold * 1000;
    if(p === 'out')  return bOut  * 1000;
    return 3000;
  }

  function runPhase(){
    const p = phases[phaseIdx];
    if(p === 'in'){
      $('blText').textContent = 'Breathe In';
      $('breathPacer').style.transform = 'translate(-50%,-50%) scale(1.12)';
      triggerBreathPulse('in');
    } else if(p === 'hold'){
      $('blText').textContent = 'Hold';
      $('breathPacer').style.transform = 'translate(-50%,-50%) scale(1.12)';
    } else {
      // out — full breath completed
      breathCount++;
      $('blText').textContent = 'Breathe Out';
      $('breathPacer').style.transform = 'translate(-50%,-50%) scale(0.88)';
      triggerBreathPulse('out');

      if(numEl){
        numEl.textContent = breathCount;
        const pct = totalBreaths > 0 ? breathCount / totalBreaths : 0;
        const r = Math.round(160 + pct * 40);
        const g = Math.round(210 + pct * 15);
        numEl.style.color = `rgba(${r},${g},240,${0.7 + pct * 0.25})`;
        numEl.style.textShadow = `0 0 ${20+pct*20}px rgba(120,180,220,${0.3+pct*0.3})`;
        pulseBreathNum();
      }
      updateDots(breathCount, totalBreaths);
    }

    // Advance to next phase after this phase's duration
    phaseIdx = (phaseIdx + 1) % phases.length;
    breathInterval = setTimeout(runPhase, phaseDuration(p));
  }

  runPhase();
}

window.showPhase=function(p){
  ['checkinOv','mirrorOv','vaultOv'].forEach(id=>{$(id).className='ov'});
  $('breathPacer').style.display='none';
  stopOrbitDot();

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Ascen BreathWorx — Production Demo v6</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@200;300;400;500;600;700&display=swap');
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: #000; font-family: 'Outfit', -apple-system, sans-serif; color: #fff; overflow: hidden; }
  .view { display: none; width: 100vw; height: 100vh; position: relative; overflow: hidden; }
  .view.active { display: block; }

.mode-sw { position: fixed; top: 14px; left: 14px; z-index: 200; display: flex; background: rgba(2,8,18,0.85); backdrop-filter: blur(12px); border-radius: 20px; overflow: hidden; border: 1px solid rgba(160,196,232,0.1); }
.mode-btn { padding: 8px 14px; font-family: 'Outfit', sans-serif; font-size: 11px; font-weight: 500; color: rgba(160,196,232,0.4); cursor: pointer; border: none; background: transparent; letter-spacing: 0.5px; transition: all 0.3s; }
.mode-btn.active { background: rgba(160,196,232,0.1); color: rgba(200,220,240,0.85); }

/* ================================================================
   IMMERSIVE OCEAN
================================================================ */
.ocean-bg { position: absolute; inset: 0; transition: background 3s ease; }
.stars { position: absolute; inset: 0; z-index: 1; }
.star { position: absolute; border-radius: 50%; animation: twinkle var(--speed) ease-in-out infinite; }
@keyframes twinkle { 0%,100%{opacity:0.15} 50%{opacity:var(--max-op)} }

.aurora-container { position: absolute; top: 0; left: 0; width: 100%; height: 55%; z-index: 2; overflow: hidden; opacity: 0; transition: opacity 4s ease; }
.aurora-band { position: absolute; width: 250%; height: 100%; left: -75%; filter: blur(50px); }
.ab1 { top: 0; height: 40%; animation: aDrift1 20s ease-in-out infinite alternate; }
.ab2 { top: 8%; height: 35%; animation: aDrift2 25s ease-in-out infinite alternate; }
.ab3 { top: 3%; height: 30%; animation: aDrift3 18s ease-in-out infinite alternate; }
.ab4 { top: 12%; height: 28%; animation: aDrift4 22s ease-in-out infinite alternate; }
.ab5 { top: 5%; height: 32%; animation: aDrift5 16s ease-in-out infinite alternate; }
@keyframes aDrift1 { 0%{transform:translateX(-8%) skewX(-4deg)} 100%{transform:translateX(8%) skewX(4deg)} }
@keyframes aDrift2 { 0%{transform:translateX(6%) skewX(3deg)} 100%{transform:translateX(-6%) skewX(-3deg)} }
@keyframes aDrift3 { 0%{transform:translateX(-5%) skewX(-2deg) scaleY(0.9)} 100%{transform:translateX(5%) skewX(2deg) scaleY(1.1)} }
@keyframes aDrift4 { 0%{transform:translateX(4%) rotate(-1deg)} 100%{transform:translateX(-4%) rotate(1deg)} }
@keyframes aDrift5 { 0%{transform:translateX(-7%) scaleX(0.95)} 100%{transform:translateX(7%) scaleX(1.05)} }

.waves { position: absolute; inset: 0; z-index: 3; }
.wave { position: absolute; left: -40px; right: -40px; height: 3px; border-radius: 2px; opacity: 0.08; animation: waveDrift var(--speed) ease-in-out infinite alternate; transition: all 2s; }
@keyframes waveDrift { from{transform:translateX(-30px)} to{transform:translateX(30px)} }

.plankton-layer { position: absolute; inset: 0; z-index: 4; }
.particle { position: absolute; border-radius: 50%; animation: drift var(--speed) ease-in-out infinite alternate, pulse var(--pulse) ease-in-out infinite; transition: all 2s; }
@keyframes drift { 0%{transform:translate(0,0)} 33%{transform:translate(var(--dx),var(--dy))} 66%{transform:translate(calc(var(--dx)*-0.5),calc(var(--dy)*0.7))} 100%{transform:translate(calc(var(--dx)*-1),calc(var(--dy)*-0.3))} }
@keyframes pulse { 0%,100%{opacity:var(--min-op)} 50%{opacity:var(--max-op)} }

/* ================================================================
   LIGHT SOURCE SYSTEM — you become the light
================================================================ */

/* The main radiance — a slow, breathing glow that grows from Luno/user
   positioned at the organism's screen anchor (bottom ~8%, center) */
.light-source-layer {
  position: absolute; inset: 0; z-index: 5;
  pointer-events: none;
  mix-blend-mode: screen;
  opacity: 0;
  transition: opacity 4s ease;
}

/* Light rays — conic fan from the same source point, slow rotation */
.light-rays-layer {
  position: absolute; inset: 0; z-index: 4;
  pointer-events: none;
  mix-blend-mode: screen;
  opacity: 0;
  transition: opacity 5s ease;
  /* Anchor rotation around Luno's screen position */
  transform-origin: 50% 91%;
  animation: raysRotate 110s linear infinite;
}
@keyframes raysRotate { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }

/* User becomes a co-source of light — emanates from porthole position */
.user-light {
  position: absolute;
  top: 30px; right: 20px;
  width: 180px; height: 180px;
  border-radius: 50%;
  z-index: 14;
  pointer-events: none;
  mix-blend-mode: screen;
  opacity: 0;
  transition: opacity 5s ease, width 4s ease, height 4s ease;
}

/* Breath pulse rings — expand outward from Luno on each inhale/exhale */
@keyframes bPulseExpand {
  0%   { opacity: var(--start-op); transform: translate(-50%,-50%) scale(1); }
  100% { opacity: 0; transform: translate(-50%,-50%) scale(var(--end-scale)); }
}

/* Source revelation text — appears during breathing at lifetime milestones */
.source-text {
  position: absolute;
  bottom: 17%;
  left: 50%;
  transform: translateX(-50%);
  font-size: 12px;
  font-weight: 300;
  color: rgba(200,220,240,0.55);
  letter-spacing: 2.5px;
  z-index: 21;
  pointer-events: none;
  text-align: center;
  opacity: 0;
  transition: opacity 4s ease;
  font-style: italic;
  white-space: nowrap;
  text-shadow: 0 0 20px rgba(120,180,220,0.4);
}
.source-text.visible { opacity: 1; }

/* ================================================================ */

/* Luno organism */
.luno-container { position: absolute; bottom: 8%; left: 50%; transform: translateX(-50%); z-index: 10; transition: all 2s; }
.luno { position: relative; display: flex; align-items: center; justify-content: center; animation: lunoDrift 8s ease-in-out infinite alternate; }
@keyframes lunoDrift { 0%{transform:translateX(-5px)} 100%{transform:translateX(5px)} }
.luno-outer,.luno-mid,.luno-core { position: absolute; border-radius: 50%; transition: all 2s ease; z-index: 1; }
.luno-center { position: absolute; border-radius: 50%; background: #fff; transition: all 2s ease; z-index: 2; }
.luno-branch { position: absolute; border-radius: 1px; transform-origin: center bottom; transition: all 1.5s ease; z-index: 3; }
.luno-orbit { position: absolute; border-radius: 50%; border: 1px solid transparent; animation: orbitSpin var(--orbit-speed) linear infinite; transition: all 2s; pointer-events: none; z-index: 3; }
@keyframes orbitSpin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }
.orbit-node { position: absolute; border-radius: 50%; }
.emanation { position: absolute; border-radius: 50%; pointer-events: none; animation: emanate var(--em-speed) ease-out infinite; z-index: 3; }
@keyframes emanate { 0%{opacity:0.6;transform:translate(0,0) scale(1)} 100%{opacity:0;transform:translate(var(--em-dx),var(--em-dy)) scale(0.3)} }

/* Face SVG */
.luno-face {
  position: absolute; z-index: 12;
  pointer-events: none; transition: opacity 3s ease;
  animation: faceBreathe 8s ease-in-out infinite;
}
@keyframes faceBreathe { 0%,100%{transform:scale(1)} 50%{transform:scale(1.02)} }
.luno-face svg { width: 100%; height: 100%; overflow: visible; }
.face-glow {
  position: absolute; border-radius: 50%;
  pointer-events: none; transition: all 3s ease;
  filter: blur(15px); z-index: 10;
}

/* Porthole */
.porthole { position: absolute; top: 60px; right: 32px; width: 140px; height: 140px; z-index: 15; transition: all 2s; }
.porthole-glass { width: 100%; height: 100%; border-radius: 50%; overflow: hidden; position: relative; mask-image: radial-gradient(circle at center, black 55%, transparent 72%); -webkit-mask-image: radial-gradient(circle at center, black 55%, transparent 72%); }
.porthole-feed { width: 100%; height: 100%; background: linear-gradient(135deg, #0a1828, #162838, #0a1420); display: flex; align-items: center; justify-content: center; }
.face-sil { width: 50px; height: 62px; border-radius: 50% 50% 45% 45%; background: rgba(120,160,190,0.08); border: 1px solid rgba(120,160,190,0.06); position: relative; }
.face-sil::after { content:''; position: absolute; bottom: -18px; left: 50%; transform: translateX(-50%); width: 60px; height: 24px; border-radius: 50% 50% 0 0; background: rgba(120,160,190,0.05); border: 1px solid rgba(120,160,190,0.04); border-bottom: none; }
.p-glow { position: absolute; inset: -8px; border-radius: 50%; pointer-events: none; transition: all 2s; }
.p-caustics { position: absolute; inset: 0; border-radius: 50%; overflow: hidden; pointer-events: none; opacity: 0.08; animation: cShift 12s ease-in-out infinite alternate; }
.p-caustics::before { content:''; position: absolute; inset: -20px; background: radial-gradient(ellipse at 30% 40%, rgba(160,220,255,0.4), transparent 50%), radial-gradient(ellipse at 70% 60%, rgba(160,220,255,0.3), transparent 40%); animation: cDrift 8s ease-in-out infinite alternate; }
@keyframes cShift { 0%{opacity:0.06} 100%{opacity:0.12} }
@keyframes cDrift { 0%{transform:translate(-5px,-3px)} 100%{transform:translate(5px,3px) rotate(10deg)} }
.pulse-ring { position: absolute; inset: -4px; border-radius: 50%; border: 1px solid transparent; animation: pRing 1s ease-out infinite; pointer-events: none; }
@keyframes pRing { 0%{transform:scale(0.95);border-color:rgba(120,170,210,0.12)} 100%{transform:scale(1.08);border-color:transparent} }

.bio-rd { position: absolute; top: 210px; right: 32px; width: 140px; text-align: center; z-index: 15; }
.bio-row { display: flex; justify-content: center; align-items: baseline; gap: 4px; margin-bottom: 2px; }
.bio-lbl { font-size: 9px; font-weight: 300; color: rgba(120,160,190,0.3); letter-spacing: 1px; text-transform: uppercase; }
.bio-val { font-size: 13px; font-weight: 300; color: rgba(140,180,210,0.5); transition: color 2s; }

/* Coherence rings */
.coh-rings { position: absolute; top: 50%; left: 24px; transform: translateY(-50%); width: 100px; height: 100px; z-index: 15; }
.coh-rings-label { position: absolute; bottom: -18px; left: 50%; transform: translateX(-50%); font-size: 8px; font-weight: 300; color: rgba(120,160,190,0.25); letter-spacing: 1.5px; text-transform: uppercase; white-space: nowrap; }
.coh-ring { position: absolute; border-radius: 50%; border: 1.5px solid rgba(120,170,210,0.2); transition: all 1.8s cubic-bezier(0.25, 0.1, 0.25, 1); box-sizing: border-box; }
.coh-ring-heart { animation: ringDrift1 4s ease-in-out infinite alternate; }
.coh-ring-breath { animation: ringDrift2 5s ease-in-out infinite alternate; }
.coh-ring-nervous { animation: ringDrift3 6s ease-in-out infinite alternate; }
@keyframes ringDrift1 { 0%{transform:translate(0,0)} 100%{transform:translate(var(--drift-x,3px),var(--drift-y,2px))} }
@keyframes ringDrift2 { 0%{transform:translate(0,0)} 100%{transform:translate(var(--drift-x,-2px),var(--drift-y,-3px))} }
@keyframes ringDrift3 { 0%{transform:translate(0,0)} 100%{transform:translate(var(--drift-x,2px),var(--drift-y,-2px))} }
.coh-ring.aligned { animation: ringPulseAligned 3s ease-in-out infinite; }
@keyframes ringPulseAligned { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(0,0) scale(1.04)} }

.top-bar { position: absolute; top: 0; left: 0; right: 0; height: 48px; padding: 0 32px; display: flex; align-items: center; justify-content: space-between; z-index: 30; }
.phase-lbl { font-size: 11px; font-weight: 600; letter-spacing: 3px; color: rgba(160,196,232,0.6); text-transform: uppercase; }
.sess-title { font-size: 11px; font-weight: 300; color: rgba(160,196,232,0.3); position: absolute; left: 50%; transform: translateX(-50%); }

.dialogue { position: absolute; top: 12%; left: 50%; transform: translateX(-50%); max-width: 580px; text-align: center; padding: 0 40px; z-index: 20; }
.dialogue-text { font-size: 20px; font-weight: 300; line-height: 1.8; color: rgba(200,220,240,0.88); }
.dialogue-text .hl { color: rgba(255,225,160,0.92); font-weight: 400; }

.breath-pacer { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 200px; height: 200px; border-radius: 50%; display: flex; align-items: center; justify-content: center; z-index: 20; transition: all 2s; }
.breath-ring { position: absolute; inset: 0; border-radius: 50%; border: 1px solid rgba(160,196,232,0.15); transition: all 2s; }
.breath-fill { width: 70%; height: 70%; border-radius: 50%; background: radial-gradient(circle, rgba(120,170,210,0.25), rgba(80,130,170,0.08) 70%, transparent); display: flex; align-items: center; justify-content: center; }
.orbit-dot { position: absolute; width: 12px; height: 12px; border-radius: 50%; background: rgba(160,196,232,0.95); box-shadow: 0 0 10px rgba(160,196,232,0.8), 0 0 22px rgba(160,196,232,0.4); transform-origin: center; pointer-events: none; transition: background 0.4s, box-shadow 0.4s; z-index: 21; }
.bl-text { font-size: 15px; font-weight: 300; color: rgba(200,220,240,0.7); letter-spacing: 1px; }
.bl-count { display: none; } /* hidden — replaced by elegant counter */

/* ── ELEGANT BREATH COUNTER ── */
#breathCounter {
  position: absolute;
  bottom: -72px;
  left: 50%;
  transform: translateX(-50%);
  display: none;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  pointer-events: none;
  z-index: 25;
}

/* Floating pulsing number */
#breathNumWrap {
  display: flex;
  align-items: baseline;
  gap: 5px;
}
#breathNum {
  font-size: 38px;
  font-weight: 200;
  color: rgba(160,210,240,0.85);
  font-family: 'Outfit', sans-serif;
  letter-spacing: -1px;
  line-height: 1;
  transition: color 1s ease;
  text-shadow: 0 0 20px rgba(120,180,220,0.4);
}
#breathNumOf {
  font-size: 11px;
  font-weight: 300;
  color: rgba(160,196,232,0.3);
  font-family: 'Outfit', sans-serif;
  letter-spacing: 1.5px;
  padding-bottom: 4px;
}

/* Dot arc */
#breathDots {
  display: flex;
  gap: 7px;
  align-items: center;
  height: 14px;
}
.bdot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: rgba(120,170,210,0.2);
  border: 1px solid rgba(120,170,210,0.25);
  transition: all 0.6s ease;
  flex-shrink: 0;
}
.bdot.done {
  background: rgba(78,205,196,0.7);
  border-color: rgba(78,205,196,0.8);
  box-shadow: 0 0 6px rgba(78,205,196,0.5);
}
.bdot.active {
  background: rgba(200,230,255,0.9);
  border-color: rgba(200,230,255,1);
  box-shadow: 0 0 10px rgba(200,230,255,0.7);
  transform: scale(1.35);
}

@keyframes breathPulseNum {
  0%   { transform: scale(1);    opacity: 0.85; }
  20%  { transform: scale(1.12); opacity: 1; }
  100% { transform: scale(1);    opacity: 0.85; }
}
.tap-prompt { position: absolute; bottom: 3%; left: 50%; transform: translateX(-50%); font-size: 13px; font-weight: 300; color: rgba(160,196,232,0.35); letter-spacing: 1px; z-index: 20; cursor: pointer; animation: tp 3s ease-in-out infinite; }
@keyframes tp { 0%,100%{opacity:0.35} 50%{opacity:0.6} }

.ov { position: absolute; inset: 0; z-index: 40; display: none; align-items: center; justify-content: center; flex-direction: column; }
.ov.active { display: flex; }
.ov-bg { position: absolute; inset: 0; background: rgba(2,8,18,0.88); backdrop-filter: blur(12px); }
.ov-c { position: relative; z-index: 2; display: flex; flex-direction: column; align-items: center; }
.ci-q { font-size: 18px; font-weight: 300; color: rgba(200,220,240,0.8); margin-bottom: 32px; }
.ci-opts { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; max-width: 480px; }
.ci-btn { padding: 10px 24px; border-radius: 24px; border: 1px solid rgba(160,196,232,0.15); background: rgba(160,196,232,0.04); color: rgba(200,220,240,0.65); font-size: 14px; font-weight: 300; cursor: pointer; font-family: 'Outfit', sans-serif; }
.m-stats { display: flex; gap: 60px; margin-bottom: 40px; } .m-stat { text-align: center; }
.m-val { font-size: 38px; font-weight: 200; letter-spacing: 2px; color: rgba(160,196,232,0.7); } .m-val.gold { color: rgba(210,185,100,0.75); }
.m-lbl { font-size: 10px; color: rgba(160,196,232,0.35); letter-spacing: 2px; text-transform: uppercase; margin-top: 8px; }
.m-truth { font-size: 17px; font-weight: 300; color: rgba(200,220,240,0.65); max-width: 420px; text-align: center; line-height: 1.8; margin-bottom: 40px; }
.m-cont { font-size: 11px; color: rgba(160,196,232,0.3); letter-spacing: 2px; cursor: pointer; text-transform: uppercase; }
.v-prompt { font-size: 17px; font-weight: 300; color: rgba(200,220,240,0.75); max-width: 480px; text-align: center; line-height: 1.8; margin-bottom: 32px; font-style: italic; }
.v-input { width: 480px; min-height: 120px; padding: 20px; background: rgba(20,40,60,0.4); border: 1px solid rgba(160,196,232,0.1); border-radius: 12px; color: rgba(200,220,240,0.85); font-size: 16px; font-family: 'Outfit', sans-serif; font-weight: 300; line-height: 1.7; resize: none; outline: none; }
.v-seal { margin-top: 24px; padding: 12px 40px; background: rgba(160,196,232,0.06); border: 1px solid rgba(160,196,232,0.15); border-radius: 24px; color: rgba(160,196,232,0.6); font-size: 12px; letter-spacing: 2px; cursor: pointer; font-family: 'Outfit', sans-serif; }
.v-skip { margin-top: 16px; font-size: 11px; color: rgba(160,196,232,0.25); cursor: pointer; }

.ctrls { position: absolute; bottom: 0; left: 0; right: 0; background: rgba(0,0,0,0.92); padding: 12px 20px; display: flex; align-items: center; gap: 14px; flex-wrap: wrap; z-index: 50; border-top: 1px solid rgba(160,196,232,0.06); }
.cg { display: flex; align-items: center; gap: 5px; }
.cl { font-size: 9px; color: rgba(160,196,232,0.35); letter-spacing: 1px; text-transform: uppercase; white-space: nowrap; }
.cv { font-size: 12px; color: rgba(160,196,232,0.6); min-width: 44px; text-align: center; font-variant-numeric: tabular-nums; }
.ctrls input[type="range"] { width: 110px; accent-color: #5A90B0; }
.sd { background: rgba(160,196,232,0.06); border: 1px solid rgba(160,196,232,0.12); border-radius: 14px; padding: 4px 12px; }
.sd .sn { font-size: 16px; font-weight: 600; color: rgba(200,220,240,0.8); font-variant-numeric: tabular-nums; }
.sd .sl { font-size: 9px; color: rgba(160,196,232,0.35); letter-spacing: 1px; }
.char-sw { display: flex; background: rgba(2,8,18,0.7); border-radius: 14px; overflow: hidden; border: 1px solid rgba(160,196,232,0.08); }
.char-btn { padding: 5px 12px; font-size: 10px; border: none; background: transparent; color: rgba(160,196,232,0.4); cursor: pointer; font-family: 'Outfit', sans-serif; transition: all 0.3s; }
.char-btn.active { background: rgba(160,196,232,0.1); color: rgba(200,220,240,0.8); }
.fi { font-size: 9px; color: rgba(160,196,232,0.25); }
.pbs { display: flex; gap: 4px; margin-left: auto; flex-wrap: wrap; }
.pb { padding: 4px 9px; border-radius: 12px; font-size: 9px; border: 1px solid rgba(160,196,232,0.1); background: transparent; color: rgba(160,196,232,0.4); cursor: pointer; font-family: 'Outfit', sans-serif; }
.pb.active { background: rgba(160,196,232,0.08); border-color: rgba(160,196,232,0.25); color: rgba(160,196,232,0.75); }

/* Participant */
#participantView { background: linear-gradient(135deg, #020812, #0D1B2A, #020812); overflow-y: auto; }
.aw { max-width: 480px; margin: 0 auto; padding: 60px 16px 40px; }
.ah { text-align: center; padding-bottom: 20px; } .ah h1 { font-size: 22px; font-weight: 600; } .ah p { font-size: 13px; color: rgba(160,196,232,0.6); margin-top: 4px; }
.si { text-align: center; margin-bottom: 20px; } .si h3 { font-size: 15px; font-weight: 500; color: rgba(160,196,232,0.6); margin-bottom: 8px; }
.ptr { width: 100%; height: 6px; background: rgba(255,255,255,0.1); border-radius: 3px; overflow: hidden; } .pfl { height: 100%; background: linear-gradient(90deg, #3A6888, #8EC8E8); border-radius: 3px; }
.cs { display: flex; gap: 12px; margin-bottom: 20px; }
.co { flex: 1; text-align: center; padding: 12px; background: rgba(20,40,60,0.5); border: 2px solid rgba(160,196,232,0.15); border-radius: 14px; cursor: pointer; font-family: 'Outfit', sans-serif; color: #fff; font-size: 14px; }
.co.act { border-color: rgba(160,196,232,0.5); background: rgba(160,196,232,0.1); } .co small { display: block; font-size: 11px; opacity: 0.5; margin-top: 2px; }
.pa { width: 130px; height: 130px; border-radius: 50%; margin: 0 auto 14px; border: 2px solid rgba(160,196,232,0.3); box-shadow: 0 0 25px rgba(20,40,60,0.5); animation: pab 8s ease-in-out infinite; }
@keyframes pab { 0%,100%{transform:scale(1)} 50%{transform:scale(1.04)} }
.pd { background: rgba(20,40,60,0.6); border-radius: 12px; padding: 14px 18px; margin-bottom: 14px; border-left: 4px solid rgba(160,196,232,0.4); }
.pd .dn { font-size: 12px; color: rgba(160,196,232,0.6); margin-bottom: 4px; } .pd .dt { font-size: 14px; line-height: 1.5; font-weight: 300; font-style: italic; }
.pbv { margin: 16px 0; text-align: center; }
.pdots { display: flex; justify-content: center; gap: 8px; margin-bottom: 8px; }
.pdt { width: 10px; height: 10px; border-radius: 50%; background: rgba(160,196,232,0.6); animation: dw 2s ease-in-out infinite; }
.pdt:nth-child(2){animation-delay:0.3s} .pdt:nth-child(3){animation-delay:0.6s}
@keyframes dw { 0%,100%{opacity:0.3;transform:scale(0.8)} 50%{opacity:1;transform:scale(1.2)} }

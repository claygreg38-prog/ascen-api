/* ================================================================
   RAILWAY API INTEGRATION
   Base: https://hearty-optimism-production-2eb6.up.railway.app
   Auth: x-api-key header on every call
================================================================ */
const API_BASE = 'https://hearty-optimism-production-2eb6.up.railway.app';
const API_KEY  = 'ascen-fr-2026-prod';

function apiGet(path){
  return fetch(API_BASE+path,{headers:{'x-api-key':API_KEY}}).then(r=>r.json()).catch(()=>null);
}
function apiPost(path,body){
  return fetch(API_BASE+path,{method:'POST',headers:{'x-api-key':API_KEY,'Content-Type':'application/json'},body:JSON.stringify(body)}).then(r=>r.json()).catch(()=>null);
}

/* User identity — persisted in localStorage */
let userId = localStorage.getItem('ascen_uid');
if(!userId){ userId='user_'+Math.random().toString(36).slice(2,11); localStorage.setItem('ascen_uid',userId); }

/* Progress cache */
let completedSessions = JSON.parse(localStorage.getItem('ascen_progress')||'{}');

/* API status dot */
(function addStatusDot(){
  const dot = document.createElement('div');
  dot.id = 'apiDot';
  dot.style.cssText = 'position:fixed;top:14px;right:16px;z-index:999;display:flex;align-items:center;gap:6px;pointer-events:none;';
  dot.innerHTML = '<div id="apiPip" style="width:7px;height:7px;border-radius:50%;background:#f5a040;box-shadow:0 0 8px #f5a040"></div><span id="apiLbl" style="font-size:9px;color:rgba(160,196,232,0.4);letter-spacing:1.5px;font-family:Outfit,sans-serif;">connecting</span>';
  document.body.appendChild(dot);
})();

function setApiStatus(s){
  const pip=$('apiPip'),lbl=$('apiLbl');
  if(!pip||!lbl) return;
  const map={live:['#4ecdc4','#4ecdc4'],offline:['#e87fa3','#e87fa3'],connecting:['#f5a040','#f5a040']};
  const c=map[s]||map.connecting;
  pip.style.background=c[0]; pip.style.boxShadow='0 0 8px '+c[1]; lbl.textContent=s;
}

/* Session data from API */
let apiSessions = [];
let sessionStartTime = null;

/* Load sessions + progress on startup */
apiGet('/api/fr/sessions').then(data=>{
  if(data && data.success){
    apiSessions = data.sessions || [];
    setApiStatus('live');
    injectSessionPicker();
  } else {
    setApiStatus('offline');
  }
});

apiGet('/api/fr/progress/'+userId).then(data=>{
  if(data && data.success && data.progress){
    data.progress.forEach(r=>{ completedSessions[r.session_number]=true; });
    localStorage.setItem('ascen_progress', JSON.stringify(completedSessions));
    updatePickerMarkers();
  }
});

/* SESSION PICKER — injected into controls bar */
let activeApiSession = null;

function injectSessionPicker(){
  if(!apiSessions.length) return;

  // Add "Sessions" button to controls bar
  const ctrls = document.querySelector('.ctrls');
  if(!ctrls || document.getElementById('sessPickerBtn')) return;

  const btn = document.createElement('button');
  btn.id = 'sessPickerBtn';
  btn.textContent = 'Sessions ▾';
  btn.style.cssText = 'padding:5px 14px;background:rgba(160,196,232,0.06);border:1px solid rgba(160,196,232,0.15);border-radius:14px;color:rgba(160,196,232,0.6);font-size:10px;letter-spacing:1.5px;cursor:pointer;font-family:Outfit,sans-serif;';
  btn.onclick = toggleSessionPanel;
  ctrls.insertBefore(btn, ctrls.firstChild);

  buildSessionPanel();
}

function buildSessionPanel(){
  if(document.getElementById('sessPanel')) return;

  const panel = document.createElement('div');
  panel.id = 'sessPanel';
  panel.style.cssText = 'display:none;position:fixed;inset:0 0 0 0;background:rgba(2,8,18,0.96);z-index:200;overflow-y:auto;padding:60px 20px 120px;';

  // Group by arc
  const arcs = {};
  apiSessions.forEach(s=>{ const a=s.arc||'foundation'; if(!arcs[a])arcs[a]=[]; arcs[a].push(s); });

  let html = '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;"><div style="font-size:22px;font-weight:300;color:rgba(200,220,240,0.85);font-family:Outfit,sans-serif;">Your Journey</div><button onclick="toggleSessionPanel()" style="background:transparent;border:1px solid rgba(160,196,232,0.15);border-radius:20px;color:rgba(160,196,232,0.5);padding:7px 18px;cursor:pointer;font-family:Outfit,sans-serif;font-size:11px;letter-spacing:1px;">close</button></div>';

  Object.entries(arcs).forEach(([arc, list])=>{
    html += `<div style="margin-bottom:24px;"><div style="font-size:9px;letter-spacing:2.5px;color:rgba(210,185,100,0.7);text-transform:uppercase;font-family:Outfit,sans-serif;margin-bottom:10px;padding-left:6px;border-left:2px solid rgba(210,185,100,0.4);">${arc.replace(/_/g,' ')}</div>`;
    list.forEach(s=>{
      const done = completedSessions[s.session_number] ? '◈' : '';
      const doneStyle = done ? 'border-color:rgba(78,205,196,0.3);' : '';
      html += `<div class="api-sess-row" data-snum="${s.session_number}" style="display:flex;align-items:center;gap:12px;padding:12px 14px;margin-bottom:6px;background:rgba(14,28,50,0.5);border:1px solid rgba(160,196,232,0.07);${doneStyle}border-radius:10px;cursor:pointer;" onclick="selectApiSession(${s.session_number})">
        <span style="font-size:9px;color:rgba(160,196,232,0.35);font-family:Outfit,sans-serif;min-width:2.5rem;">${String(s.session_number).padStart(3,'0')}</span>
        <span style="flex:1;font-size:16px;font-weight:300;color:rgba(200,220,240,0.85);font-family:Outfit,sans-serif;">${s.title||'Session '+s.session_number}</span>
        <span style="font-size:9px;color:rgba(160,196,232,0.3);font-family:Outfit,sans-serif;">${Math.round((s.duration_seconds||720)/60)}m</span>
        <span style="color:#4ecdc4;font-size:11px;">${done}</span>
      </div>`;
    });
    html += '</div>';
  });

  panel.innerHTML = html;
  document.body.appendChild(panel);
}

function updatePickerMarkers(){
  document.querySelectorAll('.api-sess-row').forEach(row=>{
    const snum = parseInt(row.dataset.snum);
    if(completedSessions[snum]){
      row.style.borderColor='rgba(78,205,196,0.3)';
      const tick = row.querySelector('span:last-child');
      if(tick) tick.textContent='◈';
    }
  });
}

window.toggleSessionPanel = function(){
  const p = document.getElementById('sessPanel');
  if(!p) return;
  p.style.display = p.style.display==='none' ? 'block' : 'none';
};

window.selectApiSession = function(snum){
  const s = apiSessions.find(x=>x.session_number===snum);
  if(!s) return;
  activeApiSession = s;

  // Update slider + title
  document.getElementById('sessSlider').value = snum;
  sessNum = snum;
  document.querySelector('.sess-title').textContent = `Session ${snum} — ${s.title||''}`;

  // Update breath ratio if session defines one
  if(s.ratio){
    const parts = s.ratio.split('-').map(Number);
    if(parts.length>=2) window._breathRatio = parts;
  }

  // Update vault prompt
  if(s.vault_prompt){
    const vEl = document.querySelector('.v-prompt');
    if(vEl) vEl.textContent = '"'+s.vault_prompt+'"';
  }

  // Update Luno arrival dialogue
  if(s.luno_arrival){
    const dEl = document.getElementById('dText');
    if(dEl) dEl.innerHTML = s.luno_arrival;
  }

  render();
  updateP();
  toggleSessionPanel();
  sessionStartTime = Date.now();
};

/* SAVE PROGRESS on vault seal or mirror continue */
const origVaultSeal = document.querySelector('.v-seal');
if(origVaultSeal){
  origVaultSeal.addEventListener('click', async function(){
    if(!activeApiSession) return;
    const text = document.querySelector('.v-input')?.value||'';
    if(text.trim()){
      await apiPost('/api/fr/vault',{
        user_id: userId,
        session_number: activeApiSession.session_number,
        vault_response: text,
        session_type: 'individual'
      });
    }
    await saveProgress();
  });
}

// Also save on mirror "continue →"
const mirrorCont = document.querySelector('.m-cont');
if(mirrorCont){
  const origOnclick = mirrorCont.getAttribute('onclick');
  mirrorCont.onclick = async function(){
    await saveProgress();
    if(origOnclick) eval(origOnclick);
  };
}

async function saveProgress(){
  if(!activeApiSession) return;
  const duration = sessionStartTime ? Math.round((Date.now()-sessionStartTime)/1000) : 0;
  const cohVal = parseInt(document.getElementById('cohSlider')?.value||'50');
  const result = await apiPost('/api/fr/progress',{
    user_id: userId,
    session_number: activeApiSession.session_number,
    completed: true,
    coherence_score: cohVal/100,
    duration_seconds: duration,
    session_type: 'individual'
  });
  if(result && result.success){
    completedSessions[activeApiSession.session_number] = true;
    localStorage.setItem('ascen_progress', JSON.stringify(completedSessions));
    updatePickerMarkers();
  }
}

})();

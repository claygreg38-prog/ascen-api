================================================================ */
function renderCoherenceRings(I, coreCol){
  const coh = I;
  const boxSz = 100;
  const rings = [
    {id:'cohRingHeart', sz:86, label:'heart'},
    {id:'cohRingBreath', sz:58, label:'breath'},
    {id:'cohRingNervous', sz:32, label:'nervous'}
  ];
  const maxDrift = 8*(1-coh);
  const borderOp = 0.12+coh*0.55;
  const glowStr = coh>0.4?(coh-0.4)/0.6:0;
  const isAligned = coh>0.85;

  rings.forEach((r,i)=>{
    const el=$(r.id);
    const angle=(i*2.1+Date.now()*0.0002*(i+1))%(Math.PI*2);
    const offX=isAligned?0:Math.sin(angle)*maxDrift*(i===0?1:i===1?0.7:0.4);
    const offY=isAligned?0:Math.cos(angle*1.3)*maxDrift*(i===0?0.6:i===1?1:0.8);
    const left=(boxSz-r.sz)/2+offX;
    const top=(boxSz-r.sz)/2+offY;
    const ringCol=coreCol;
    const bw=1.2+coh*0.8;
    el.style.setProperty('--drift-x',`${(Math.sin(i*1.5)*maxDrift*0.5).toFixed(1)}px`);
    el.style.setProperty('--drift-y',`${(Math.cos(i*2.1)*maxDrift*0.5).toFixed(1)}px`);
    let shadow='none';
    if(glowStr>0) shadow=`0 0 ${4+glowStr*12}px ${rgba(ringCol,glowStr*0.4)},inset 0 0 ${2+glowStr*6}px ${rgba(ringCol,glowStr*0.2)}`;
    el.style.width=r.sz+'px';el.style.height=r.sz+'px';
    el.style.left=left+'px';el.style.top=top+'px';
    el.style.borderColor=rgba(ringCol,borderOp);
    el.style.borderWidth=bw+'px';
    el.style.boxShadow=shadow;
    if(isAligned){el.classList.add('aligned');el.classList.remove('coh-ring-'+r.label)}
    else{el.classList.remove('aligned');if(!el.classList.contains('coh-ring-'+r.label))el.classList.add('coh-ring-'+r.label)}
  });
}

